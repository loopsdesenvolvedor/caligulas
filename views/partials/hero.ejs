<main id="hero">
  <%- include('title') %>
  <section id="card-group">
    <div class="cards">
    <% if (typeof isCategory === 'boolean' && isCategory) { %>

      <% videos.forEach(video => { %>
        <div class="card">
          <a class="card-img" href="/video/<%= video.id %>">
            <div>
              <img src="/files/<%= video.banner %>" alt="<%= video.title %>" />
              <div class="card-alerts">
                <span class="card-time"><%= video.time %></span>
                <% if (recentVideos.some(recent => recent.id === video.id)) { %>
                <span class="card-notification" class="card-time">NOVO</span>
                <% } %>
              </div>
            </div>
          </a>
          <a class="card-title" href="/video/<%= video.id %>">
            <div><%= video.title %></div>
          </a>
        </div>
    <% }) %> 
 
    <% } else { %>
      <% if (result && result.videos && result.videos.rows.length > 0) { %> 
        <% result.videos.rows.forEach(video => { %>
        <div class="card">
          <a class="card-img" href="/video/<%= video.id %>">
            <div>
              <img src="/files/<%= video.banner %>" alt="<%= video.title %>" />
              <div class="card-alerts">
                <span class="card-time"><%= video.time %></span>
                <% if (recentVideos.some(recent => recent.id === video.id)) { %>
                <span class="card-notification" class="card-time">NOVO</span>
                <% } %>
              </div>
            </div>
          </a>
          <a class="card-title" href="/video/<%= video.id %>">
            <div><%= video.title %></div>
          </a>
        </div>
        <% }) %> 
        <% } else { %> 
          <% videos.forEach(video => { %>
              <div class="card">
                <a class="card-img" href="/video/<%= video.id %>">
                  <div>
                    <img src="/files/<%= video.banner %>" alt="<%= video.title %>" />
                    <div class="card-alerts">
                      <span class="card-time"><%= video.time %></span>
                      <% if (recentVideos.some(recent => recent.id === video.id)) { %>
                      <span class="card-notification" class="card-time">NOVO</span>
                      <% } %>
                    </div>
                  </div>
                </a>
                <a class="card-title" href="/video/<%= video.id %>">
                  <div><%= video.title %></div>
                </a>
              </div>
          <% }) %> 
        
        <% } %>
    <% } %>


    </div>
<%- include('pagination') %>
  </section>
</main>
